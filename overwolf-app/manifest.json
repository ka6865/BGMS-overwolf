{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "BGMS Companion",
    "author": "BGMS",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.170.0",
    "description": "A lightweight in-game PUBG companion overlay for live session awareness and post-match BGMS handoff.",
    "icon": "assets/bgms-icon.png",
    "icon_gray": "assets/bgms-icon-gray.png",
    "website": "https://bgms.kr"
  },
  "permissions": [
    "GameInfo",
    "GameEvents",
    "Hotkeys"
  ],
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [
        10906
      ]
    },
    "game_events": [
      10906
    ],
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [
            10906
          ],
          "wait_for_stable_framerate": 30
        },
        "start_minimized": true
      }
    ],
    "windows": {
      "background": {
        "file": "background.html",
        "is_background_page": true
      },
      "desktop": {
        "file": "desktop.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "size": {
          "width": 980,
          "height": 640
        },
        "min_size": {
          "width": 760,
          "height": 520
        }
      },
      "in_game": {
        "file": "in-game.html",
        "in_game_only": true,
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "grab_keyboard_focus": false,
        "size": {
          "width": 420,
          "height": 220
        },
        "start_position": {
          "top": 72,
          "left": 72
        }
      }
    },
    "hotkeys": {
      "toggle_overlay": {
        "title": "Show or hide BGMS overlay",
        "action-type": "custom",
        "default": "Ctrl+Shift+B"
      }
    }
  }
}
